# NATS Configuration

# NATS server URL
# For local development, use: nats://localhost:4222
# For production, update to your NATS server URL
NATS_URL=nats://localhost:4222

# Optional NATS authentication
# NATS_USER=
# NATS_PASSWORD=
# NATS_TOKEN=

# Auth Provider: 'identity-zero' (default) or 'better-auth'
# AUTH_PROVIDER=identity-zero

# Better Auth (when AUTH_PROVIDER=better-auth)
# BETTER_AUTH_JWKS_URL=https://api.bree.ai/api/auth/jwks
# Or use base URL: BETTER_AUTH_URL=https://api.bree.ai

# Existing configuration
RAGSTER_API_URL=https://agent-collective-ragster.fly.dev/api
AGENTX_URL=https://agent-collective-agentx.fly.dev
ANTIMATTER_URL=https://agent-collective-antimatter.fly.dev
