# TokenHouse Gateway Configuration

# JWT Secret (change in production)
JWT_SECRET=your-secret-key-change-in-production

# Admin Secret (for /admin endpoints)
ADMIN_SECRET=admin-secret-change-me

# Platform Owner's Master API Keys
OPENAI_API_KEY=sk-proj-your-openai-master-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-master-key

# Database (optional - using in-memory for demo)
# DATABASE_URL=mongodb://localhost:27017/tokenhouse

# NATS (optional - for real-time analytics)
# NATS_URL=nats://localhost:4222
