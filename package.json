{
  "name": "bree-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "BREE AI - Multi-tenant document intelligence platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:kat": "bun --filter kat-ai dev",
    "dev:habitaware": "bun --filter habitaware-ai dev",
    "dev:genius": "bun --filter genius-talent dev",
    "dev:vineyard": "bun --filter the-vineyard dev",
    "dev:tracker": "bun --filter ai-tracker dev",
    "dev:api": "bun --filter bree-ai-api dev",
    "dev:all": "bun run dev:api & bun run dev:kat & bun run dev:habitaware & bun run dev:genius & bun run dev:vineyard & bun run dev:tracker",
    "build:kat": "bun --filter kat-ai build",
    "build:habitaware": "bun --filter habitaware-ai build",
    "build:genius": "bun --filter genius-talent build",
    "build:vineyard": "bun --filter the-vineyard build",
    "build:tracker": "bun --filter ai-tracker build",
    "build:api": "bun --filter bree-ai-api build",
    "test": "bun run test:api && bun run test:genius",
    "test:api": "bun --filter bree-ai-api test",
    "test:genius": "bun --filter genius-talent test",
    "build:all": "bun run build:api && bun run build:kat && bun run build:habitaware && bun run build:genius && bun run build:vineyard && bun run build:tracker",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
