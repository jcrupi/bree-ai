{
  "name": "bree-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "BREE AI - Multi-tenant document intelligence platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:kat": "bun --filter kat-ai dev",
    "dev:habitaware": "bun --filter habitaware-ai dev",
    "dev:genius": "bun --filter live-ai-talent dev",
    "dev:vineyard": "bun --filter the-vineyard dev",
    "dev:tracker": "bun --filter ai-tracker dev",
    "dev:api": "bun --filter bree-ai-api dev",
    "dev:antimatter": "bun --filter antimatterdb dev",
    "dev:antimatter-ui": "bun --filter antimatterdb dev:ui",
    "dev:antimatter-admin": "bun --filter antimatter-admin dev",
    "dev:all": "bun run dev:api & bun run dev:kat & bun run dev:habitaware & bun run dev:genius & bun run dev:vineyard & bun run dev:tracker & bun run dev:antimatter & bun run dev:antimatter-ui & bun run dev:antimatter-admin",
    "build:kat": "bun --filter kat-ai build",
    "build:habitaware": "bun --filter habitaware-ai build",
    "build:genius": "bun --filter live-ai-talent build",
    "build:vineyard": "bun --filter the-vineyard build",
    "build:tracker": "bun --filter ai-tracker build",
    "build:api": "bun --filter bree-ai-api build",
    "build:antimatter": "bun --filter antimatterdb build",
    "build:antimatter-admin": "bun --filter antimatter-admin build",
    "test": "bun run test:api && bun run test:genius",
    "test:api": "bun --filter bree-ai-api test",
    "test:genius": "bun --filter live-ai-talent test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:all": "bun run build:api && bun run build:kat && bun run build:habitaware && bun run build:genius && bun run build:vineyard && bun run build:tracker && bun run build:antimatter && bun run build:antimatter-admin",
    "clean": "rm -rf node_modules packages/*/node_modules apps/*/node_modules",
    "dev:fatapps": "bun --filter fatapps-ai dev",
    "build:fatapps": "bun --filter fatapps-ai build",
    "dev:talent-village": "bun --filter talent-village dev",
    "build:talent-village": "bun --filter talent-village build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}